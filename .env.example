# ============================================================================
# spec2program - Environment configuration (EXAMPLE)
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# The ".env" file is git-ignored and will never be committed.
# ============================================================================

# Which LLM backend to use:
#   mock       -> deterministic offline generator, NO API key needed (great for demos)
#   openrouter -> OpenRouter.ai (one key, access to many model providers)
#   openai     -> any OpenAI-compatible Chat Completions endpoint directly
LLM_PROVIDER=mock

# --- Settings used only when LLM_PROVIDER is "openrouter" or "openai" ------
# Your API key (leave blank in mock mode).
LLM_API_KEY=

# Base URL of the OpenAI-compatible API.
#   OpenRouter : https://openrouter.ai/api/v1   (ignored when LLM_PROVIDER=openrouter,
#                                                 which always targets OpenRouter directly)
#   OpenAI     : https://api.openai.com/v1
#   Also works with Azure OpenAI (via gateway), Together AI, Groq, Ollama, etc.
LLM_BASE_URL=https://api.openai.com/v1

# Model name to request.
#   OpenRouter example : anthropic/claude-sonnet-5
#   OpenAI example      : gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# Sampling temperature (0 = deterministic, higher = more creative).
LLM_TEMPERATURE=0.1

# Request timeout in seconds.
LLM_TIMEOUT=60

# --- OpenRouter attribution headers (optional, not secret) -----------------
# OpenRouter's docs recommend sending these to identify the calling app.
OPENROUTER_SITE_URL=https://github.com/iamvisheshsrivastava/spec2program
OPENROUTER_SITE_NAME=spec2program

# --- Application settings ---------------------------------------------------
# CORS origins allowed to call the API (comma-separated). "*" allows all.
CORS_ORIGINS=*
